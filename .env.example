# Choose provider: "openai" or "google". 
EMBEDDING_PROVIDER=google

# OpenAI Settings 
OPENAI_API_KEY=

# Google Settings 
GOOGLE_API_KEY=
GOOGLE_EMBEDDING_MAX_RETRIES=6
GOOGLE_EMBEDDING_RETRY_BASE_SECONDS=2
GOOGLE_EMBEDDING_REQUEST_DELAY_SECONDS=1

CORS_ALLOW_ORIGINS=http://localhost:3000,https://deep-scholar-hoangphan.vercel.app
DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-1-ap-southeast-1.pooler.supabase.com:5432/postgres?sslmode=require

# Cloudflare R2 Config
AWS_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=apac

# LlamaParse - AI-powered PDF Parser (https://cloud.llamaindex.ai)
LLAMAPARSE_API_KEY=

# Django Backend internal URL
BACKEND_API_URL=http://host.docker.internal:8000/api/v1

# Internal service key (must match INTERNAL_SERVICE_KEY in Backend .env)
INTERNAL_SERVICE_KEY=

OPENROUTER_API_KEY=sk-or-v1-xxxxx

# Redis server for cache, async job status, and short-term chat memory.
# Use redis:// for plain Redis, or rediss:// if your server requires TLS.
REDIS_URL=rediss://default:password@your-upstash-host.upstash.io:6379
# REDIS_URL=rediss://default:<PASSWORD>@<UPSTASH_ENDPOINT>:6379
REDIS_SOCKET_CONNECT_TIMEOUT_SECONDS=2
REDIS_SOCKET_TIMEOUT_SECONDS=2
REDIS_HEALTH_CHECK_INTERVAL_SECONDS=30
